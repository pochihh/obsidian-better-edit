{
	"name": "obsidian-better-edit",
	"version": "0.1.0",
	"description": "A multi-feature editing toolbox for Obsidian",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"styles:build": "node scripts/build-styles.mjs",
		"dev": "node scripts/build-styles.mjs && node esbuild.config.mjs",
		"build": "node scripts/build-styles.mjs && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@codemirror/language": "^6.12.3",
		"@codemirror/state": "6.5.0",
		"@codemirror/view": "6.38.6",
		"@eslint/js": "9.30.1",
		"@lezer/common": "^1.5.2",
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.2.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.59.2"
	},
	"dependencies": {
		"emojilib": "^4.0.3",
		"obsidian": "latest"
	}
}
